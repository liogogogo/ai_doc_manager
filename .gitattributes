# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary

# Git attributes for better diffs
*.rs diff=rust
*.lock linguist-generated=true
package-lock.json linguist-generated=true
Cargo.lock linguist-generated=true

# Exclude from exports
.gitignore export-ignore
.gitattributes export-ignore
.githooks/ export-ignore
.ai/ export-ignore
